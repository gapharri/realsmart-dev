# Shared Laravel Cloud secrets for RealSmart suite apps.
# Copy to ~/.config/realsmart/cloud-shared.env and fill in values from 1Password.
#
# GOOGLE_* can also come from ~/.config/realsmart/google-oauth.env (sync-cloud-env.sh reads both).
# If cloud-shared.env is missing, sync-cloud-env.sh bootstraps FLUX/GEMINI from live smartcops.

FLUX_USERNAME=
FLUX_LICENSE_KEY=
GEMINI_API_KEY=
